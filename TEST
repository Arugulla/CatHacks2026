  .zone-hint {
    position: absolute;
    bottom: 12px;
    font-size: 0.7rem;
    color: rgba(200,169,110,0.4);
    letter-spacing: 0.1em;
  }

  /* Muzzle flash overlay */
  .muzzle-flash {
    position: fixed; inset: 0; z-index: 100;
    background: rgba(255,220,50,0.6);
    pointer-events: none;
    opacity: 0;
  }
