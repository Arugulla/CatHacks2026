<script>
// ── AUDIO ENGINE ──
const AC = window.AudioContext || window.webkitAudioContext;
let audioCtx;

function ensureAudio() {
  if (!audioCtx) audioCtx = new AC();
}

function playGunshot() {
  ensureAudio();
  const buf = audioCtx.createBuffer(1, audioCtx.sampleRate * 0.6, audioCtx.sampleRate);
  const d = buf.getChannelData(0);
  for (let i = 0; i < d.length; i++) {
    const t = i / audioCtx.sampleRate;
    d[i] = (Math.random() * 2 - 1) * Math.exp(-t * 12) * 1.5;
    if (i < 800) d[i] += Math.sin(i * 0.3) * Math.exp(-t * 30) * 0.8;
  }
  const src = audioCtx.createBufferSource();
  src.buffer = buf;
  const gain = audioCtx.createGain();
  gain.gain.setValueAtTime(1, audioCtx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.5);
  src.connect(gain).connect(audioCtx.destination);
  src.start();
}

function playClick() {
  ensureAudio();
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  osc.frequency.value = 800;
  osc.type = 'square';
  gain.gain.setValueAtTime(0.15, audioCtx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.08);
  osc.connect(gain).connect(audioCtx.destination);
  osc.start(); osc.stop(audioCtx.currentTime + 0.08);
}

function playBuzz() {
  ensureAudio();
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  osc.frequency.value = 120;
  osc.type = 'sawtooth';
  gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.3);
  osc.connect(gain).connect(audioCtx.destination);
  osc.start(); osc.stop(audioCtx.currentTime + 0.3);
}

function playCountBleep(n) {
  ensureAudio();
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  const freqs = { 3: 440, 2: 550, 1: 660 };
  osc.frequency.value = freqs[n] || 440;
  osc.type = 'sine';
  gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.12);
  osc.connect(gain).connect(audioCtx.destination);
  osc.start(); osc.stop(audioCtx.currentTime + 0.15);
}

function playDrawHorn() {
  ensureAudio();
  [440, 550, 660, 880].forEach((f, i) => {
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.frequency.value = f;
    osc.type = 'sawtooth';
    const t = audioCtx.currentTime + i * 0.04;
    gain.gain.setValueAtTime(0, t);
    gain.gain.linearRampToValueAtTime(0.15, t + 0.02);
    gain.gain.exponentialRampToValueAtTime(0.001, t + 0.3);
    osc.connect(gain).connect(audioCtx.destination);
    osc.start(t); osc.stop(t + 0.35);
  });
}

// ── GAME STATE ──
const MODES = {
  classic:   { name: 'Classic', counts: [3,2,1] },
  tricky:    { name: 'Tricky',  counts: null }, // dynamic
  sudden:    { name: 'Sudden Death', counts: [] },
  marathon:  { name: 'Best of 3', counts: [3,2,1], winsNeeded: 2 }
};

const WIN_LINES = [
  "Slicker than a greased rattlesnake.",
  "Fastest gun in the territory.",
  "The devil blinked first.",
  "Even the crows tipped their hats.",
  "That draw'd make Billy the Kid nervous."
];
const LOSE_LINES = [
  "Boot Hill's got another tenant.",
  "Your mama warned you, stranger.",
  "That's why you stick to poker.",
  "The undertaker sends his regards.",
  "Try again, greenhorn."
];

const TWIST_MESSAGES = {
  classic: ['3... 2... 1... DRAW!', 'Classic showdown rules.', 'Three counts to glory.'],
  tricky:  ['The count is... unpredictable.', 'Trust nothing. Draw everything.', 'Even the numbers lie out here.'],
  sudden:  ['No warnings. No mercy.', 'DRAW comes without warning.', 'Blink and you\'re buried.'],
  marathon:['Best of 3 rounds wins.', 'Survive. Endure. Prevail.', 'Three duels. One legend.']
};

let currentMode = 'classic';
let gamePhase = 'idle'; // idle, countdown, live, result
let drawTime = 0;
let timeoutId = null;
let roundNum = 1;
let wins = 0;
let bestMs = null;
let tooEarlyThisRound = false;

function selectMode(btn) {
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  currentMode = btn.dataset.mode;
}

function startDuel() {
  ensureAudio();
  roundNum = 1; wins = 0; bestMs = null;
  showScreen('game-screen');
  updateStatusBar();
  runRound();
}

function runRound() {
  gamePhase = 'countdown';
  tooEarlyThisRound = false;

  // Reset draw zone
  const zone = document.getElementById('draw-zone');
  zone.className = 'draw-zone';
  document.getElementById('draw-text').style.display = 'none';
  document.getElementById('countdown').style.display = 'block';
  document.getElementById('zone-hint').textContent = 'CLICK WHEN YOU SEE DRAW!';

  // Twist badge
  const badge = document.getElementById('twist-badge');
  const msgs = TWIST_MESSAGES[currentMode];
  badge.textContent = msgs[Math.floor(Math.random() * msgs.length)];

  // Pick countdown sequence
  let counts;
  if (currentMode === 'tricky') {
    counts = buildTrickyCount();
    showTwistBadge(counts);
  } else if (currentMode === 'sudden') {
    counts = [];
  } else {
    counts = [...MODES[currentMode].counts];
  }

  runCountdown(counts, 0);
}

function buildTrickyCount() {
  // Random twists: might stay on a number, skip, or add an extra
  const twists = [
    [3,2,1],
    [3,3,2,1],
    [3,2,2,1],
    [3,2,1,1],
    [3,2],
    [3,3,2,2,1],
    [3,2,0,1],  // "0" = keep blank, distracts
    [2,1],
  ];
  return twists[Math.floor(Math.random() * twists.length)];
}

function showTwistBadge(counts) {
  const badge = document.getElementById('twist-badge');
  const specialCounts = JSON.stringify(counts);
  if (counts.includes(0)) badge.textContent = '⚠ THE COUNT LIES — STAY SHARP';
  else if (counts.filter((v,i,a) => a.indexOf(v) !== i).length) badge.textContent = '🎲 THE COUNT REPEATS — HOLD YOUR NERVE';
  else if (counts.length < 3) badge.textContent = '⚡ SHORT COUNT — FASTER DRAW NEEDED';
}

function runCountdown(counts, idx) {
  if (gamePhase !== 'countdown') return;

  const cd = document.getElementById('countdown');

  if (idx >= counts.length) {
    // Time to DRAW
    const delay = 400 + Math.random() * 1800;
    setTimeout(() => {
      if (gamePhase !== 'countdown') return;
      cd.textContent = '';
      triggerDraw();
    }, delay);
    return;
  }

  const num = counts[idx];
  cd.textContent = num === 0 ? '?' : num;
  cd.className = 'countdown-display flash';
  setTimeout(() => cd.className = 'countdown-display', 350);

  if (num !== 0) playCountBleep(num);

  const delay = currentMode === 'tricky' ? 600 + Math.random() * 600 : 800;
  timeoutId = setTimeout(() => runCountdown(counts, idx + 1), delay);
}

function triggerDraw() {
  gamePhase = 'live';
  drawTime = performance.now();

  document.getElementById('countdown').style.display = 'none';
  const drawEl = document.getElementById('draw-text');
  drawEl.style.display = 'block';
  document.getElementById('zone-hint').textContent = '⬆ CLICK NOW! ⬆';

  const zone = document.getElementById('draw-zone');
  zone.classList.add('live');

  playDrawHorn();

  // AI opponent (random 200–600ms)
  const aiMs = Math.round(200 + Math.random() * 400);
  timeoutId = setTimeout(() => {
    if (gamePhase === 'live') {
      endRound('ai', aiMs, aiMs);
    }
  }, aiMs);
}

function playerShot() {
  if (gamePhase === 'countdown') {
    // Too early!
    clearTimeout(timeoutId);
    gamePhase = 'result';
    tooEarlyThisRound = true;
    playBuzz();
    const zone = document.getElementById('draw-zone');
    zone.classList.add('early');
    showResult('early', 0, 0);
    return;
  }
  if (gamePhase !== 'live') return;

  const reactionMs = Math.round(performance.now() - drawTime);
  clearTimeout(timeoutId);

  const aiMs = Math.round(200 + Math.random() * 400);
  const playerWon = reactionMs < aiMs;

  muzzleFlash();
  playGunshot();
  endRound(playerWon ? 'player' : 'ai', reactionMs, aiMs);
}

function endRound(winner, playerMs, aiMs) {
  gamePhase = 'result';

  if (winner === 'player') wins++;

  if (winner === 'player' && (bestMs === null || playerMs < bestMs)) {
    bestMs = playerMs;
  }

  showResult(winner, Math.round(playerMs), Math.round(aiMs));
}

function showResult(winner, playerMs, aiMs) {
  showScreen('result-screen');

  const headline = document.getElementById('result-headline');
  const sub = document.getElementById('result-sub');
  const timeDiv = document.getElementById('time-display');
  const nextBtn = document.getElementById('next-btn');

  const isMarathon = currentMode === 'marathon';
  const winsNeeded = 2;

  if (winner === 'early') {
    headline.textContent = 'TOO EARLY!';
    headline.className = 'result-headline early';
    sub.textContent = 'A cheat and a coward. Holster up and try again.';
    timeDiv.innerHTML = '<div style="color:#ff6600;font-size:0.9rem;">You drew before DRAW! appeared.</div>';
    nextBtn.textContent = '🔫 TRY AGAIN';
    return;
  }

  if (winner === 'player') {
    headline.textContent = isMarathon ? `ROUND ${roundNum} — YOU!` : 'YOU WIN!';
    headline.className = 'result-headline win';
    sub.textContent = WIN_LINES[Math.floor(Math.random() * WIN_LINES.length)];
    spawnParticles(['🌟','⭐','🔥','💥'], 12);
    if (isMarathon && wins >= winsNeeded) {
      headline.textContent = '🏆 CHAMPION!';
      sub.textContent = 'The legend of the West rides again.';
    }
  } else {
    headline.textContent = isMarathon ? `ROUND ${roundNum} — AI!` : 'TOO SLOW!';
    headline.className = 'result-headline lose';
    sub.textContent = LOSE_LINES[Math.floor(Math.random() * LOSE_LINES.length)];
  }

  // Time display
  const isNewRecord = winner === 'player' && bestMs === playerMs && playerMs < 300;
  const displayPlayer = Math.round(playerMs);
  const displayAi = Math.round(aiMs);
  timeDiv.innerHTML = `
    <div class="player-time">
      <div class="player-label">YOUR DRAW</div>
      <div class="player-ms ${winner === 'player' ? 'best' : ''}">${displayPlayer}ms${isNewRecord ? '<span class="new-record">NEW RECORD</span>' : ''}</div>
    </div>
    <div class="player-time">
      <div class="player-label">OUTLAW AI</div>
      <div class="player-ms p2">${displayAi}ms</div>
    </div>
  `;

  // Marathon mode
  if (isMarathon) {
    const losesNeeded = 2;
    const aiWins = roundNum - wins - (winner === 'early' ? 0 : 0);
    if (wins >= winsNeeded) {
      nextBtn.textContent = '🏆 CHAMPION!';
      nextBtn.onclick = goHome;
    } else if ((roundNum - wins) >= losesNeeded) {
      headline.textContent = 'OUTGUNNED!';
      nextBtn.textContent = '😤 REMATCH';
      nextBtn.onclick = startDuel;
    } else {
      nextBtn.textContent = `⚔ ROUND ${roundNum + 1}`;
      nextBtn.onclick = () => { roundNum++; updateStatusBar(); runRound(); showScreen('game-screen'); };
    }
  } else {
    nextBtn.textContent = '🔫 DRAW AGAIN';
    nextBtn.onclick = () => { roundNum++; updateStatusBar(); runRound(); showScreen('game-screen'); };
  }

  updateStatusBar();
}

function nextRound() {
  roundNum++;
  updateStatusBar();
  runRound();
  showScreen('game-screen');
}

function goHome() {
  clearTimeout(timeoutId);
  gamePhase = 'idle';
  roundNum = 1; wins = 0;
  showScreen('start-screen');
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function updateStatusBar() {
  document.getElementById('round-num').textContent = roundNum;
  document.getElementById('win-count').textContent = wins;
  document.getElementById('best-time').textContent = bestMs !== null ? bestMs + 'ms' : '—';
}

function muzzleFlash() {
  const el = document.getElementById('muzzle');
  el.classList.remove('bang');
  void el.offsetWidth;
  el.classList.add('bang');
}

function spawnParticles(chars, count) {
  for (let i = 0; i < count; i++) {
    const el = document.createElement('div');
    el.className = 'particle';
    el.textContent = chars[Math.floor(Math.random() * chars.length)];
    el.style.left = (20 + Math.random() * 60) + 'vw';
    el.style.top = (30 + Math.random() * 40) + 'vh';
    el.style.setProperty('--dx', (Math.random() * 200 - 100) + 'px');
    el.style.setProperty('--dy', (-80 - Math.random() * 160) + 'px');
    el.style.animationDelay = Math.random() * 0.3 + 's';
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 1200);
  }
}

// Prevent accidental double-clicks
document.addEventListener('keydown', e => {
  if (e.code === 'Space' || e.code === 'Enter') {
    e.preventDefault();
    playerShot();
  }
});
</script>
