    gap: 1rem;
  }

  .result-card {
    background: rgba(10,5,0,0.85);
    border: 3px solid var(--gold);
    border-radius: 4px;
    padding: 2rem 2.5rem;
    max-width: 480px;
    width: 100%;
    box-shadow: 0 0 0 6px rgba(212,160,23,0.15), 8px 8px 40px rgba(0,0,0,0.8);
    animation: result-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
  }
  @keyframes result-in {
    0% { transform: scale(0.5) rotate(-10deg); opacity: 0; }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
  }

  .result-headline {
    font-family: 'Rye', cursive;
    font-size: clamp(2rem, 7vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }
  .result-headline.win { color: var(--gold); text-shadow: 0 0 20px rgba(212,160,23,0.5); }
  .result-headline.lose { color: var(--blood); text-shadow: 0 0 20px rgba(139,26,26,0.5); }
  .result-headline.early { color: #ff6600; }

  .result-sub {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--dust);
    margin-bottom: 1.2rem;
  }

  .time-display {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin: 1rem 0;
    flex-wrap: wrap;
  }

  .player-time {
    text-align: center;
  }
  .player-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--dust);
    margin-bottom: 0.2rem;
  }
  .player-ms {
    font-family: 'Rye', cursive;
    font-size: 1.8rem;
    color: var(--gold);
  }
  .player-ms.p2 { color: var(--dust); }
  .player-ms.best { color: #88ff88; }

  .divider {
    border: none;
    border-top: 1px solid rgba(200,169,110,0.3);
    margin: 1rem 0;
  }

  .btn-row {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  /* ── PARTICLES ── */
  .particle {
    position: fixed;
    pointer-events: none;
    font-size: 1.2rem;
    animation: particle-fly 0.8s ease-out forwards;
    z-index: 200;
  }
  @keyframes particle-fly {
    0% { transform: translate(0,0) scale(1); opacity: 1; }
    100% { transform: translate(var(--dx), var(--dy)) scale(0); opacity: 0; }
  }

  /* ── STATUS BAR ── */
  .status-bar {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  .status-item {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--dust);
  }
  .status-value {
    font-family: 'Rye', cursive;
    color: var(--gold);
    font-size: 0.9rem;
  }

  /* Too early red screen */
  .draw-zone.early { border-color: var(--blood); animation: shake 0.4s ease-out; }
  @keyframes shake {
    0%,100%{transform:translateX(0)} 20%{transform:translateX(-10px)} 40%{transform:translateX(10px)} 60%{transform:translateX(-8px)} 80%{transform:translateX(8px)}
  }

  /* Hint pulse on DRAW */
  .draw-zone.live {
    border-color: #ff2200;
    box-shadow: inset 0 0 40px rgba(0,0,0,0.5), 0 0 20px rgba(255,34,0,0.4), 0 0 0 6px rgba(255,34,0,0.15);
    cursor: crosshair;
  }

  /* ── MODE SELECTOR ── */
  .mode-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    width: 100%;
    max-width: 360px;
    margin-top: 0.8rem;
  }
  .mode-btn {
    background: rgba(200,169,110,0.08);
    border: 1px solid var(--dust);
    color: var(--dust);
    font-family: 'Special Elite', cursive;
    font-size: 0.75rem;
    padding: 0.5rem;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.05em;
  }
  .mode-btn:hover, .mode-btn.selected {
    background: rgba(212,160,23,0.2);
    border-color: var(--gold);
    color: var(--gold);
  }

  .mode-label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: rgba(200,169,110,0.5);
    margin-top: 0.8rem;
    margin-bottom: 0.2rem;
  }

  /* record */
  .new-record {
    display: inline-block;
    background: var(--gold);
    color: var(--dark);
    font-size: 0.65rem;
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
    letter-spacing: 0.1em;
    animation: pop 0.3s ease-out;
    margin-left: 0.3rem;
    vertical-align: middle;
  }
  @keyframes pop { 0%{transform:scale(0)} 70%{transform:scale(1.2)} 100%{transform:scale(1)} }
</style>
</head>
